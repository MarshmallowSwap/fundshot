{
  "version": 2,
  "builds": [
    {
      "src": "landing.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin.html",
      "use": "@vercel/static"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "bybit-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "binance-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "okx-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "hyperliquid-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "hyperliquid-logo.png",
      "use": "@vercel/static"
    },
    {
      "src": "sw.js",
      "use": "@vercel/static"
    },
    {
      "src": "manifest.json",
      "use": "@vercel/static"
    },
    {
      "src": "dydx-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "bitget-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "gate-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "docs.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/bybit-logo.svg",
      "dest": "/bybit-logo.svg"
    },
    {
      "src": "/binance-logo.svg",
      "dest": "/binance-logo.svg"
    },
    {
      "src": "/okx-logo.svg",
      "dest": "/okx-logo.svg"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/dashboard",
      "dest": "/index.html"
    },
    {
      "src": "/",
      "dest": "/landing.html"
    },
    {
      "src": "/hyperliquid-logo.svg",
      "dest": "/hyperliquid-logo.svg"
    },
    {
      "src": "/hyperliquid-logo.png",
      "dest": "/hyperliquid-logo.png"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/dydx-logo.svg",
      "dest": "/dydx-logo.svg"
    },
    {
      "src": "/bitget-logo.svg",
      "dest": "/bitget-logo.svg"
    },
    {
      "src": "/gate-logo.svg",
      "dest": "/gate-logo.svg"
    },
    {
      "src": "/docs",
      "dest": "/docs.html"
    },
    {
      "src": "/(.*)",
      "dest": "/landing.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).svg",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/svg+xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}