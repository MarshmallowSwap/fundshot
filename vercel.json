{
  "version": 2,
  "builds": [
    {
      "src": "landing.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin.html",
      "use": "@vercel/static"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "bybit-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "binance-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "okx-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "hyperliquid-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "hyperliquid-logo.png",
      "use": "@vercel/static"
    },
    {
      "src": "sw.js",
      "use": "@vercel/static"
    },
    {
      "src": "manifest.json",
      "use": "@vercel/static"
    },
    {
      "src": "dydx-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "bitget-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "gate-logo.svg",
      "use": "@vercel/static"
    },
    {
      "src": "docs.html",
      "use": "@vercel/static"
    },
    {
      "src": "faq.html",
      "use": "@vercel/static"
    },
    {
      "src": "guide.html",
      "use": "@vercel/static"
    },
    {
      "src": "track-record.html",
      "use": "@vercel/static"
    },
    {
      "src": "sitemap.xml",
      "use": "@vercel/static"
    },
    {
      "src": "robots.txt",
      "use": "@vercel/static"
    },
    {
      "src": "learn.html",
      "use": "@vercel/static"
    },
    {
      "src": "learn-index.html",
      "use": "@vercel/static"
    },
    {
      "src": "learn-oi.html",
      "use": "@vercel/static"
    },
    {
      "src": "learn-mr.html",
      "use": "@vercel/static"
    },
    {
      "src": "favicon.ico",
      "use": "@vercel/static"
    },
    {
      "src": "favicon.png",
      "use": "@vercel/static"
    },
    {
      "src": "favicon-32x32.png",
      "use": "@vercel/static"
    },
    {
      "src": "favicon-16x16.png",
      "use": "@vercel/static"
    },
    {
      "src": "apple-touch-icon.png",
      "use": "@vercel/static"
    },
    {
      "src": "status.html",
      "use": "@vercel/static"
    },
    {
      "src": "alerts.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/bybit-logo.svg",
      "dest": "/bybit-logo.svg"
    },
    {
      "src": "/binance-logo.svg",
      "dest": "/binance-logo.svg"
    },
    {
      "src": "/okx-logo.svg",
      "dest": "/okx-logo.svg"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/dashboard",
      "dest": "/index.html"
    },
    {
      "src": "/",
      "dest": "/landing.html"
    },
    {
      "src": "/hyperliquid-logo.svg",
      "dest": "/hyperliquid-logo.svg"
    },
    {
      "src": "/hyperliquid-logo.png",
      "dest": "/hyperliquid-logo.png"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/dydx-logo.svg",
      "dest": "/dydx-logo.svg"
    },
    {
      "src": "/bitget-logo.svg",
      "dest": "/bitget-logo.svg"
    },
    {
      "src": "/gate-logo.svg",
      "dest": "/gate-logo.svg"
    },
    {
      "src": "/docs",
      "dest": "/docs.html"
    },
    {
      "src": "/faq",
      "dest": "/faq.html"
    },
    {
      "src": "/guide",
      "dest": "/guide.html"
    },
    {
      "src": "/track-record",
      "dest": "/track-record.html"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/learn/funding-rates",
      "dest": "/learn.html"
    },
    {
      "src": "/learn",
      "dest": "/learn.html"
    },
    {
      "src": "/learn",
      "dest": "/learn-index.html"
    },
    {
      "src": "/learn/open-interest",
      "dest": "/learn-oi.html"
    },
    {
      "src": "/learn/mean-reversion",
      "dest": "/learn-mr.html"
    },
    {
      "src": "/apple-touch-icon.png",
      "dest": "/apple-touch-icon.png"
    },
    {
      "src": "/favicon-16x16.png",
      "dest": "/favicon-16x16.png"
    },
    {
      "src": "/favicon-32x32.png",
      "dest": "/favicon-32x32.png"
    },
    {
      "src": "/favicon.png",
      "dest": "/favicon.png"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/alerts",
      "dest": "/alerts.html"
    },
    {
      "src": "/status",
      "dest": "/status.html"
    },
    {
      "src": "/(.*)",
      "dest": "/landing.html"
    }
  ],
  "headers": [
    {
      "source": "/index",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/faq",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        },
        {
          "key": "Vary",
          "value": "*"
        }
      ]
    },
    {
      "source": "/dashboard",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/docs",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/(.*).svg",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/svg+xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}