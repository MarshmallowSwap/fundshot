# ──────────────────────────────────────────────
# Funding King Bot — Variabili d'ambiente
# Copia questo file in .env e compila i valori
# ──────────────────────────────────────────────

# ── Telegram ──────────────────────────────────
TELEGRAM_TOKEN=il_tuo_bot_token_da_botfather
CHAT_ID=il_tuo_chat_id

# ── Bybit API (Mainnet) ───────────────────────
BYBIT_API_KEY=la_tua_api_key_pubblica
BYBIT_API_SECRET=il_tuo_api_secret

# ── Impostazioni bot ──────────────────────────
JOB_INTERVAL=60          # secondi tra un ciclo e il successivo
COOLDOWN_SECONDS=120     # cooldown dopo reset Bybit

# ── Alert prossimo funding ────────────────────
FUNDING_ALERT_MINUTES=15 # minuti prima del settlement per inviare l'alert

# ── Liquidazioni WebSocket ────────────────────
LIQUIDATION_MIN_USD=100000  # soglia minima in USD per alert liquidazioni

# ── PUMP / DUMP ───────────────────────────────
PUMP_THRESHOLD_1H=5.0    # % variazione 1H per alert pump
DUMP_THRESHOLD_1H=-5.0   # % variazione 1H per alert dump

# ══════════════════════════════════════════════
# SOGLIE IBRIDE (fisse + dinamiche)
# ══════════════════════════════════════════════
#
# USE_DYNAMIC_THRESHOLDS=false  → usa solo le soglie fisse (default)
# USE_DYNAMIC_THRESHOLDS=true   → attiva la modalità ibrida
#
# Logica ibrida:
#   soglia_effettiva = max(soglia_fissa, media_rolling * moltiplicatore)
#   La soglia fissa fa sempre da FLOOR (non scende mai sotto)
#
# Moltiplicatori per livello:
#   HARD      → media × 4.0   (floor: 2.00%)
#   EXTREME   → media × 3.0   (floor: 1.50%)
#   HIGH      → media × 2.0   (floor: 1.00%)
#   CLOSE TIP → media × 1.5   (floor: 0.23%)
#
# Esempio con PEPEUSDT (media rolling 0.80%):
#   HIGH effettiva = max(1.00%, 0.80% × 2.0) = max(1.00%, 1.60%) = 1.60%
#
# Esempio con BTCUSDT (media rolling 0.01%):
#   HIGH effettiva = max(1.00%, 0.01% × 2.0) = max(1.00%, 0.02%) = 1.00%
#
# ══════════════════════════════════════════════

USE_DYNAMIC_THRESHOLDS=false
DYNAMIC_WINDOW_HOURS=24   # ore di storico rolling per calcolo media
